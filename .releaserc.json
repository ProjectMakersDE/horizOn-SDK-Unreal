{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/changelog", { "changelogFile": "CHANGELOG.md" }],
    ["@semantic-release/exec", {
      "prepareCmd": "sed -i 's/\"VersionName\": \"[^\"]*\"/\"VersionName\": \"${nextRelease.version}\"/' Plugins/HorizonSDK/HorizonSDK.uplugin && sed -i 's/version-[0-9]*\\.[0-9]*\\.[0-9]*-orange/version-${nextRelease.version}-orange/' README.md"
    }],
    ["@semantic-release/git", {
      "assets": ["CHANGELOG.md", "Plugins/HorizonSDK/HorizonSDK.uplugin", "README.md"],
      "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    "@semantic-release/github"
  ]
}
